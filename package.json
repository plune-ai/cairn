{
  "name": "@plune-ai/lex-bot",
  "version": "0.1.1",
  "description": "Autonomous QA agent that explores web pages and generates UI tests (@playwright/test) on LangGraph + Claude/OpenRouter, with self-improvement via Langfuse.",
  "type": "module",
  "license": "GPL-3.0-only",
  "author": "plune-ai",
  "keywords": [
    "qa",
    "testing",
    "test-generation",
    "playwright",
    "ui-testing",
    "langgraph",
    "ai-agent",
    "langfuse",
    "anthropic"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plune-ai/lex-bot.git"
  },
  "homepage": "https://github.com/plune-ai/lex-bot#readme",
  "bugs": {
    "url": "https://github.com/plune-ai/lex-bot/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "lex-bot": "dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "session:save": "tsx scripts/save-session.ts",
    "spike:s1-zod": "tsx scripts/spike-s1-zod.ts",
    "spike:s2-vision": "tsx scripts/spike-s2-vision.ts",
    "spike:s5-langfuse": "tsx scripts/spike-s5-langfuse.ts",
    "spike:s6-parity": "tsx scripts/spike-s6-parity.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.6",
    "@langchain/openai": "^1.4.7",
    "@langfuse/client": "^5.4.1",
    "@langfuse/langchain": "^5.4.1",
    "@langfuse/otel": "^5.4.1",
    "@langfuse/tracing": "^5.4.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@playwright/cli": "^0.1.13",
    "@playwright/test": "^1.60.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.60.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
