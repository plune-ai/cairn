# Cairn configuration. Every variable below can also be set with a CAIRN_ prefix
# (e.g. CAIRN_LLM_PROFILE, CAIRN_MAX_REPAIR). Legacy LEX_/LEXBOT_ prefixes still work
# but print a one-time deprecation warning — prefer CAIRN_ or the bare name.

# ── LLM providers (ADR-0002) ────────────────────────────────────────────────
# The profile selects which provider/models are used for each tier:
#   anthropic  — quality (Opus/Sonnet/Haiku), more expensive
#   openrouter — economical (DeepSeek/Qwen)
#   mixed      — e.g. vision on Anthropic, bulk+judge on OpenRouter
LLM_PROFILE=anthropic

ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ── Langfuse (ADR-0006) — SELF-HOSTED on your server ─────────────────────────
LANGFUSE_BASE_URL=https://langfuse.your-server.example
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Test cases ─────────────────────────────────────────────────────────────────
# Language of the generated test cases. Default English. Accepts a name (Ukrainian/Deutsch)
# or a code (en/uk/ua). The checklist can be in any language — the cases will still be in this one.
QA_TESTCASE_LANG=English

# ── Browser ──────────────────────────────────────────────────────────────────
# lib (in-process Playwright, default) | cli (experimental — needs the optional @playwright/cli package).
BROWSER_BACKEND=lib
# Browser channel — drive a system browser (bypasses automation detection, e.g. Google OAuth, and needs
# NO bundled-Chromium download, so it coexists with a project's own Playwright). Per command: --channel.
# Empty = bundled Chromium (run `cairn install-browsers`); chrome = real Google Chrome.
BROWSER_CHANNEL=chrome
